// 1. Module and Imports
module MySuperLib

use Math::Constants
use { print, log } from System::IO
use Networking::Http from "https://lib.luv/http"

// 2. Function Declarations (Optional 'fn')

// Declaration with 'fn' and explicit return
fn add(a, b) -> i32 {
    return a + b
}

// Declaration without 'fn' (Implicit return of last expression)
multiply(x, y) -> f64 {
    x * y
}

// Function with no return type and block
say_hello() {
    print("Hello!")
}

// 3. Complex Logic & Ranges
check_range(val) {
    if (val in 0...100 && val != 50) {
        return true
    } ef (val == 50 || !true) {
        return false
    } else {
        return false
    }
}

// 4. Scoping and Calls
main() {
    mut result = Math::Constants::PI * 2.0
    
    // Function call vs Declaration check
    // Parser will see this as a call because no '{' or '->' follows immediately
    say_hello()
    
    mut list = [1, 2, 3]
    
    // 5. Match and Arrows
    match status {
        "ok"    => 1,
        "error" => 0,
        _       => -1
    }
}

// 6. String Interpolation & Multi-line
mut name = "Gemini"
mut greeting = &"Hello, {name}! Your score is {10 + 5}."

mut docs = """
This is a multi-line docstring
spanning multiple lines.
"""

// 7. Scoped Path usage
System::IO::log("Test complete.")



